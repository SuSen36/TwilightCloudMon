    "cobblemon.move.colorfulgrass": "Colorful Grass",
    "cobblemon.move.colorfulgrass.desc": "Uses a mysterious power to grow plants and attack enemies. Makes the surrounding grass colorful and restores the Pokémon\u0027s HP each turn.",
    "cobblemon.move.fuaiwarfire": "Soaring Flame",
    "cobblemon.move.fuaiwarfire.desc": "Gathers intense flames on wings for a powerful fire attack. May cause the opponent to burn.",
    "cobblemon.move.hanminzj": "Abyssal Impact",
    "cobblemon.move.hanminzj.desc": "Tenses the body and charges with enough power to cross the ocean.",
    "cobblemon.move.shanfeisuo": "Flash Steel",
    "cobblemon.move.shanfeisuo.desc": "Makes the flying steel strike twice. If the opponent has 2 Pokémon, strikes each once.",
    "cobblemon.move.taijingzhan": "Terastal Slash",
    "cobblemon.move.taijingzhan.desc": "Transforms into a giant sword and slashes the opponent. Damage is doubled if the opponent is Terastallized.",
    "cobblemon.move.taijingdan": "Terastal Shield",
    "cobblemon.move.taijingdan.desc": "Transforms into a giant shield and crashes into the opponent. Damage is doubled if the opponent is Dynamaxed.",
    "cobblemon.move.linjiaren": "Scale Blade",
    "cobblemon.move.linjiaren.desc": "Cuts the opponent with powerful scales. High critical hit ratio.",
    "cobblemon.move.yuezhiwu": "Lunar Dance",
    "cobblemon.move.yuezhiwu.desc": "Covers itself in shadows and attacks with wing beats. May raise Special Attack.",
    "cobblemon.move.daiyimandong": "Malevolent Vines",
    "cobblemon.move.daiyimandong.desc": "Uses vines to sense hostility and disrupts the opponent with evil thoughts. May cause flinching.",
    "cobblemon.move.chiwujige": "Crimson Mist Ritual",
    "cobblemon.move.chiwujige.desc": "Summons crimson mist and sings an ancestral ritual song to intimidate the opponent. Raises Special Attack.",
    "cobblemon.move.suigubo": "Bone Crush Wave",
    "cobblemon.move.suigubo.desc": "Attacks with a fist wrapped in malice.",
    "cobblemon.move.anyingdan": "Shadow Bullet",
    "cobblemon.move.anyingdan.desc": "Attacks with sound waves powerful enough to shatter bones through flesh.",
    "cobblemon.move.dubaopo": "Toxic Explosion",
    "cobblemon.move.dubaopo.desc": "Triggers a toxic explosion that attacks all Pokémon around the user. The user faints after use.",
    "cobblemon.move.qiqunyiwu": "Strange Spore Dance",
    "cobblemon.move.qiqunyiwu.desc": "Performs a mysterious dance, swinging the tail to spread spores that put the opponent to sleep.",
    "cobblemon.move.bingzhiwu": "Ice Dance",
    "cobblemon.move.bingzhiwu.desc": "Performs a cold dance that raises Special Attack and Speed.",
    "cobblemon.move.guozaizhiwu": "Overload Dance",
    "cobblemon.move.guozaizhiwu.desc": "Accelerates energy consumption to boost attributes, lowering Defense and Special Defense while raising Attack, Special Attack, and Speed.",
    "cobblemon.move.zhuozhuoyanbang": "Burning Staff",
    "cobblemon.move.zhuozhuoyanbang.desc": "Swings a giant flaming staff for a fierce attack. The user also takes significant damage. May cause the opponent to burn.",
    "cobblemon.move.yuzhoupao": "Cosmic Cannon",
    "cobblemon.move.yuzhoupao.desc": "Concentrates cosmic power within and then fires it from the mouth.",
    "cobblemon.move.qianjilinshe": "Thousand Scale Shot",
    "cobblemon.move.qianjilinshe.desc": "Fires scales to attack. Hits 2-5 times in succession. Attack increases but Defense, Special Defense, and Speed decrease.",
    "cobblemon.move.guaiyaolianzha": "Strange Potion Combo",
    "cobblemon.move.guaiyaolianzha.desc": "Throws poison vials to attack the target, striking twice in one turn.",
    "cobblemon.move.finaldragonbreath": "Final Dragon Breath",
    "cobblemon.move.finaldragonbreath.desc": "Releases a dragon\u0027s breath that ends everything. Has a high chance of paralyzing the target.",
    "cobblemon.move.solarjudgment": "Solar Judgment",
    "cobblemon.move.solarjudgment.desc": "Gathers the power of the sun\u0027s flames to deliver judgment. This move always goes first.",

    "cobblemon.ability.luckyberry": "Lucky Berry",
    "cobblemon.ability.luckyberry.desc": "After eating a berry, cures status conditions and randomly boosts one stat.",
